# ============================================
# UMC Quản Lý Dự Án — Cấu hình môi trường server
# Sao chép file này thành .env rồi điền giá trị.
# ============================================

# --- BẮT BUỘC ---

# PostgreSQL (Neon): lấy tại https://console.neon.tech → Connection Details
# DATABASE_URL dùng pooled connection, DIRECT_URL dùng direct connection (cho prisma db push)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# Khóa ký JWT — BẮT BUỘC đổi khi chạy thật (chuỗi ngẫu nhiên dài ≥32 ký tự).
# Không đặt → dùng default 'umc-dev-secret-change-me' (KHÔNG an toàn).
JWT_SECRET=

# --- TÙY CHỌN ---

# Gửi email thật (OTP, reset mật khẩu, giao việc, @mention).
# Gmail: bật 2FA rồi tạo App Password tại https://myaccount.google.com/apppasswords
# Không cấu hình → OTP/token trả trong response (devOtp/devResetToken) để test.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Tính năng AI (tóm tắt thảo luận + phân tích dự án).
# Lấy key MIỄN PHÍ tại https://aistudio.google.com (không cần thẻ).
# Không có key → API trả 503, các tính năng khác vẫn chạy bình thường.
GEMINI_API_KEY=

# Domain frontend cho CORS + link trong email. Nhiều domain cách nhau dấu phẩy.
# Chạy local mặc định:
CLIENT_URL=http://localhost:5173

# Lưu file lên Cloudinary thay vì ổ đĩa local (cho deploy production).
# Không cấu hình → file lưu vào server/uploads/ (đủ cho chạy local).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
