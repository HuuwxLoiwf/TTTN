        <!-- Khung ghi chu -->
        <mxCell id="note1" value="Lưu ý: Đổi TRẠNG THÁI công việc (PUT /tasks/:id) chỉ ADMIN được phép — controller chặn nếu req.memberRole ≠ ADMIN, sau đó cũng emit task:updated + recalcProjectProgress." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;" vertex="1" parent="1">
