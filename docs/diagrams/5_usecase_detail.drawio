        <mxCell id="u5" value="Ghi khoản chi (nội dung, số tiền, nhóm, ngày chi)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="540" y="360" width="230" height="65" as="geometry" /></mxCell>
