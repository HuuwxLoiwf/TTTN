        <mxCell id="aMember" value="Thành viên&#10;dự án" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;" vertex="1" parent="1"><mxGeometry x="60" y="150" width="40" height="80" as="geometry" /></mxCell>
