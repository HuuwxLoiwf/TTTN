        <!-- Thiet bi -->
        <mxCell id="u1" value="Xem danh sách thiết bị / máy móc (theo kho hoặc theo dự án)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="260" y="100" width="230" height="70" as="geometry" /></mxCell>
