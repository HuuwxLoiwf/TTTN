        <mxCell id="bnd" value="" style="rounded=1;whiteSpace=wrap;html=1;arcSize=3;fillColor=none;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="200" y="70" width="960" height="780" as="geometry" /></mxCell>

        <mxCell id="u1" value="Đăng ký tài khoản" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="260" y="100" width="180" height="50" as="geometry" /></mxCell>
        <mxCell id="u1a" value="Kiểm tra mật khẩu mạnh&#10;(≥8 ký tự, có chữ+số)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="560" y="80" width="180" height="55" as="geometry" /></mxCell>
        <mxCell id="u1b" value="Gửi &amp; xác minh OTP&#10;(6 số, hết hạn 10 phút)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="150" width="180" height="55" as="geometry" /></mxCell>
        <mxCell id="u1c" value="Gửi lại mã OTP" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="820" y="150" width="160" height="50" as="geometry" /></mxCell>

        <mxCell id="u2" value="Đăng nhập&#10;(email + mật khẩu)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="260" y="360" width="180" height="55" as="geometry" /></mxCell>
        <mxCell id="u2a" value="Kiểm tra đã xác minh email + đã được ADMIN duyệt" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="560" y="300" width="190" height="60" as="geometry" /></mxCell>
        <mxCell id="u2b" value="Xác minh OTP 2 lớp (2FA)&#10;cấp JWT sau khi đúng" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="380" width="190" height="60" as="geometry" /></mxCell>
        <mxCell id="u2c" value="Cấp JWT (hiệu lực 7 ngày)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="820" y="380" width="180" height="55" as="geometry" /></mxCell>

        <mxCell id="u3" value="Quên mật khẩu&#10;(gửi liên kết đặt lại)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="260" y="470" width="180" height="55" as="geometry" /></mxCell>
        <mxCell id="u3a" value="Đặt lại mật khẩu bằng token&#10;(hết hạn 30 phút)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="560" y="470" width="190" height="55" as="geometry" /></mxCell>

