  <diagram id="d3_task" name="PR3 - Quan ly Cong viec">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1350" pageHeight="920" math="0" shadow="0">
      <root>
        <mxCell id="0" />
